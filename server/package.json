{
  "name": "earths-echoes-api",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Earth's Echoes API — auth, user sync, admin CMS, analytics (Railway)",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:seed": "tsx src/db/seed.ts",
    "typecheck": "tsc --noEmit"
