  "dependencies": {
    "@hono/node-server": "^1.14.0",
    "better-auth": "^1.6.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.7.8",
    "nanoid": "^5.1.5",
    "node-cron": "^3.0.3",
    "pg": "^8.15.6",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.14",
    "drizzle-kit": "^0.31.4",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
