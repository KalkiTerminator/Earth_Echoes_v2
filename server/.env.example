# Copy to server/.env for local dev (values below are safe local defaults).
# In production these are set as Railway service variables — never commit real secrets.

# Injected by Railway Postgres + platform in prod. Local default points at a
# local Postgres on port 5432 (adjust to your setup).
DATABASE_URL=postgres://postgres@localhost:5432/earths_echoes
PORT=8787

# 32+ random bytes: `openssl rand -base64 32`
BETTER_AUTH_SECRET=dev-insecure-secret-change-me-0123456789abcd

# Public URL of THIS api (used for auth callbacks + media URLs).
BETTER_AUTH_URL=http://localhost:8787
# The single browser origin allowed to send credentialed requests (the app).
APP_ORIGIN=http://localhost:5173

# Prod only: leading-dot domain so the session cookie is shared between
# app and api subdomains. Leave empty for local dev.
# COOKIE_DOMAIN=.earthsechoes.com

# Comma-separated emails auto-promoted to admin on sign-in.
ADMIN_EMAILS=prateek.owner1@gmail.com

# Uploaded media dir. In prod this is a Railway volume mount, e.g. /data.
STORAGE_DIR=./.storage

# Optional Google OAuth (leave blank to keep email+password only).
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

NODE_ENV=development

# ---- Autonomous ingestion (all optional; blank = agent layer disabled) ----
# See docs/AUTONOMOUS.md. LLMs run on Google Vertex AI (Gemini + Claude).
# GOOGLE_VERTEX_PROJECT=
# GOOGLE_VERTEX_LOCATION=us-central1
# GOOGLE_VERTEX_ANTHROPIC_LOCATION=us-east5
# GOOGLE_APPLICATION_CREDENTIALS_JSON=   # service-account JSON, single line
# INGEST_SYNTH_MODEL=claude-haiku-4-5
# INGEST_VALIDATE_MODEL=gemini-2.5-flash
# INGEST_MEDIA_MODEL=gemini-2.5-flash
# INGEST_CONTACT_EMAIL=you@example.org   # polite User-Agent for open APIs

# Data-source tokens (free-but-registered / freemium).
# IUCN_TOKEN=
# EBIRD_TOKEN=
# FLICKR_API_KEY=
# UNSPLASH_ACCESS_KEY=
# NCBI_API_KEY=
# NATURESERVE_TOKEN=

# Scrape-only enrichment via MCP (optional).
# FIRECRAWL_MCP_URL=
# FIRECRAWL_API_KEY=
# APIFY_MCP_URL=
# APIFY_TOKEN=

# Cost guardrails (US cents).
# INGEST_PER_RUN_CENTS=100
# INGEST_MONTHLY_CENTS=2000
